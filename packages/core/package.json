{
  "name": "@publishguard/core",
  "version": "0.2.0",
  "description": "Core scanning engine for PublishGuard — pre-publish safety for npm and VS Code extensions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean --out-dir dist",
    "dev": "tsup src/index.ts --format cjs --dts --watch --out-dir dist",
    "lint": "echo ok",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "glob": "^11.0.1",
    "ignore": "^6.0.2",
    "npm-packlist": "^8.0.2",
    "zod": "^3.24.1",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/npm-packlist": "^7.0.0",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "VladNoskov",
  "publisher": "VladNoskov",
  "repository": {
    "type": "git",
    "url": "https://github.com/VladNoskov/publishguard"
  },
  "keywords": [
    "publish",
    "security",
    "npm",
    "vscode",
    "scanner",
    "audit",
    "supply-chain"
  ]
}
