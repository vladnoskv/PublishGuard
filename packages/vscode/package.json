{
  "name": "publishguard",
  "displayName": "PublishGuard",
  "description": "Pre-publish safety scanner for npm packages and VS Code extensions — catches secrets, sensitive files, and metadata issues before you publish.",
  "version": "0.6.0",
  "publisher": "VladNoskov",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Linters", "Other"],
  "activationEvents": [
    "workspaceContains:package.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "publishguard.scan",
        "title": "PublishGuard: Scan Project",
        "icon": {
          "light": "resources/icon-light.png",
          "dark": "resources/icon-dark.png"
        }
      },
      {
        "command": "publishguard.quickScan",
        "title": "PublishGuard: Quick Scan"
      },
      {
        "command": "publishguard.deepScan",
        "title": "PublishGuard: Deep Scan"
      },
      {
        "command": "publishguard.refreshIssues",
        "title": "PublishGuard: Refresh Issues"
      },
      {
        "command": "publishguard.refreshDiagnostics",
        "title": "PublishGuard: Refresh Diagnostics"
      },
      {
        "command": "publishguard.clearDiagnostics",
        "title": "PublishGuard: Clear Diagnostics"
      },
      {
        "command": "publishguard.setSeverityThreshold",
        "title": "PublishGuard: Set Severity Filter"
      },
      {
        "command": "publishguard.manageDiagnostic",
        "title": "PublishGuard: Manage Finding"
      },
      {
        "command": "publishguard.fix",
        "title": "PublishGuard: Auto-Fix Issues"
      },
      {
        "command": "publishguard.init",
        "title": "PublishGuard: Generate Ignore Files"
      },
      {
        "command": "publishguard.showIssues",
        "title": "PublishGuard: Show Issues"
      },
      {
        "command": "publishguard.openSettings",
        "title": "PublishGuard: Open Settings"
      },
      {
        "command": "publishguard.openIssue",
        "title": "PublishGuard: Open Issue"
      },
      {
        "command": "publishguard.revealIssue",
        "title": "PublishGuard: Reveal in File Explorer"
      },
      {
        "command": "publishguard.deleteIssueFile",
        "title": "PublishGuard: Delete File"
      },
      {
        "command": "publishguard.suppressIssue",
        "title": "PublishGuard: Ignore This Problem"
      },
      {
        "command": "publishguard.suppressRuleInFile",
        "title": "PublishGuard: Ignore Rule in This File"
      },
      {
        "command": "publishguard.suppressFile",
        "title": "PublishGuard: Ignore This File"
      },
      {
        "command": "publishguard.suppressRuleInFolder",
        "title": "PublishGuard: Ignore Rule in This Folder"
      },
      {
        "command": "publishguard.suppressFolder",
        "title": "PublishGuard: Ignore This Folder"
      },
      {
        "command": "publishguard.suppressRuleEverywhere",
        "title": "PublishGuard: Ignore This Type of Problem"
      },
      {
        "command": "publishguard.addToPublishGuardIgnore",
        "title": "PublishGuard: Add Path to Ignore List"
      },
      {
        "command": "publishguard.ignoreExplorerFile",
        "title": "PublishGuard: Ignore This File"
      },
      {
        "command": "publishguard.ignoreExplorerFolder",
        "title": "PublishGuard: Ignore This Folder"
      },
      {
        "command": "publishguard.excludeIssueFile",
        "title": "PublishGuard: Exclude This File"
      },
      {
        "command": "publishguard.excludeIssueFolder",
        "title": "PublishGuard: Exclude This Folder"
      },
      {
        "command": "publishguard.suppressActiveIssue",
        "title": "PublishGuard: Ignore Warning at Cursor"
      },
      {
        "command": "publishguard.suppressActiveRuleEverywhere",
        "title": "PublishGuard: Ignore Warning Type at Cursor"
      },
      {
        "command": "publishguard.excludeActiveFile",
        "title": "PublishGuard: Exclude Current File"
      },
      {
        "command": "publishguard.excludeActiveFolder",
        "title": "PublishGuard: Exclude Current Folder"
      },
      {
        "command": "publishguard.copyIssue",
        "title": "PublishGuard: Copy Issue"
      },
      {
        "command": "publishguard.copyMarkdownReport",
        "title": "PublishGuard: Copy Markdown Report"
      },
      {
        "command": "publishguard.exportMarkdownReport",
        "title": "PublishGuard: Export Markdown Report"
      },
      {
        "command": "publishguard.installPreCommitHook",
        "title": "PublishGuard: Install Pre-Commit Hook"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "publishguard",
          "title": "PublishGuard",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "publishguard": [
        {
          "id": "publishguard.issues",
          "name": "Publishing Issues"
        }
      ]
    },
    "configuration": {
      "title": "PublishGuard",
      "properties": {
        "publishguard.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan after saving package.json"
        },
        "publishguard.rescanAfterIgnore": {
          "type": "boolean",
          "default": true,
          "description": "Automatically rescan after an issue or path is ignored. Disable to apply ignore changes on the next scan."
        },
        "publishguard.blockPublishOnError": {
          "type": "boolean",
          "default": true,
          "description": "Block VS Code extension publishing if errors are found"
        },
        "publishguard.includeGitIgnored": {
          "type": "boolean",
          "default": false,
          "description": "Include gitignored workspace files in secret and size scans. Publish file resolution and ignore validation are unchanged."
        },
        "publishguard.dependencyAudit": {
          "type": "boolean",
          "default": false,
          "description": "Run npm audit during scans to confirm known vulnerable dependencies. This can contact the npm registry and may take longer."
        },
        "publishguard.socketDev": {
          "type": "boolean",
          "default": false,
          "description": "Run Socket.dev CLI confirmation for medium, high, and critical supply-chain alerts. Requires the Socket CLI to be installed and configured."
        },
        "publishguard.snyk": {
          "type": "boolean",
          "default": false,
          "description": "Run Snyk CLI confirmation for medium, high, and critical dependency vulnerabilities. Requires the Snyk CLI to be installed and authenticated."
        },
        "publishguard.severityThreshold": {
          "type": "string",
          "default": "info",
          "enum": ["error", "warning", "info"],
          "description": "Minimum severity level to report"
        },
        "publishguard.scanMode": {
          "type": "string",
          "default": "full",
          "enum": ["quick", "full", "deep"],
          "description": "Default scan mode for PublishGuard scans. Quick skips source-derived capability analysis, full uses bounded source analysis, and deep broadens local/source coverage."
        },
        "publishguard.scanGitHistoryExamples": {
          "type": "boolean",
          "default": true,
          "description": "Expose the default settings webview value for scanning docs and examples that are present in git history. The saved scanner value lives in .publishguardrc.json."
        },
        "publishguard.scanUnpublishedExamples": {
          "type": "boolean",
          "default": false,
          "description": "Expose the default settings webview value for scanning unpublished docs and examples. The saved scanner value lives in .publishguardrc.json."
        },
        "publishguard.dummySecretSeverity": {
          "type": "string",
          "default": "info",
          "enum": ["off", "info", "warning", "error"],
          "description": "Expose the default settings webview value for dummy secret findings in docs and examples. The saved scanner value lives in .publishguardrc.json."
        }
      }
    },
    "menus": {
      "view/title": [
      {
        "command": "publishguard.refreshIssues",
        "when": "view == publishguard.issues",
        "group": "navigation@1"
      },
      {
        "command": "publishguard.scan",
        "when": "view == publishguard.issues",
        "group": "navigation@2"
      },
      {
        "command": "publishguard.quickScan",
        "when": "view == publishguard.issues",
        "group": "navigation@3"
      },
      {
        "command": "publishguard.deepScan",
        "when": "view == publishguard.issues",
        "group": "navigation@4"
      },
      {
        "command": "publishguard.openSettings",
        "when": "view == publishguard.issues",
        "group": "navigation@5"
      },
      {
        "command": "publishguard.setSeverityThreshold",
        "when": "view == publishguard.issues",
        "group": "navigation@6"
      },
      {
        "command": "publishguard.clearDiagnostics",
        "when": "view == publishguard.issues",
        "group": "navigation@7"
      }
      ],
      "view/item/context": [
      {
        "command": "publishguard.openIssue",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "navigation@1"
      },
      {
        "command": "publishguard.revealIssue",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "navigation@2"
      },
      {
        "command": "publishguard.suppressIssue",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "1_ignore@1"
      },
      {
        "command": "publishguard.suppressRuleInFile",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "1_ignore@2"
      },
      {
        "command": "publishguard.suppressFile",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "1_ignore@3"
      },
      {
        "command": "publishguard.suppressRuleInFolder",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "1_ignore@4"
      },
      {
        "command": "publishguard.suppressFolder",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "1_ignore@5"
      },
      {
        "command": "publishguard.suppressRuleEverywhere",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "1_ignore@6"
      },
      {
        "command": "publishguard.excludeIssueFile",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "1_ignore@7"
      },
      {
        "command": "publishguard.excludeIssueFolder",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "1_ignore@8"
      },
      {
        "command": "publishguard.copyIssue",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "inline@1"
      },
      {
        "command": "publishguard.manageDiagnostic",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "inline@2"
      },
      {
        "command": "publishguard.deleteIssueFile",
        "when": "view == publishguard.issues && viewItem == issue",
        "group": "2_modification@1"
      }
      ],
      "explorer/context": [
      {
        "command": "publishguard.ignoreExplorerFile",
        "when": "resourceScheme == file && !explorerResourceIsFolder",
        "group": "publishguard@1"
      },
      {
        "command": "publishguard.ignoreExplorerFolder",
        "when": "resourceScheme == file && explorerResourceIsFolder",
        "group": "publishguard@1"
      }
      ],
      "editor/context": [
      {
        "command": "publishguard.suppressActiveIssue",
        "when": "resourceScheme == file",
        "group": "publishguard@1"
      },
      {
        "command": "publishguard.suppressActiveRuleEverywhere",
        "when": "resourceScheme == file",
        "group": "publishguard@2"
      },
      {
        "command": "publishguard.excludeActiveFile",
        "when": "resourceScheme == file",
        "group": "publishguard@3"
      },
      {
        "command": "publishguard.excludeActiveFolder",
        "when": "resourceScheme == file",
        "group": "publishguard@4"
      }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "echo ok",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@publishguard/core": "0.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "VladNoskov",
  "repository": {
    "type": "git",
    "url": "https://github.com/VladNoskov/publishguard"
  },
  "bugs": {
    "url": "https://github.com/VladNoskov/publishguard/issues"
  },
  "homepage": "https://github.com/VladNoskov/publishguard#readme",
  "galleryBanner": {
    "color": "#007acc",
    "theme": "dark"
  },
  "keywords": [
    "publish",
    "security",
    "npm",
    "vscode-extension",
    "scanner",
    "audit",
    "supply-chain"
  ]
}
