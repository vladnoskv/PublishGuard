{
  "name": "publishguard-monorepo",
  "version": "0.4.1",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/vscode"
  ],
  "description": "PublishGuard monorepo — pre-publish safety scanner for npm and VS Code extensions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VladNoskov/publishguard"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"packages/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/*.ts\"",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=18.0.0"
  }
}
